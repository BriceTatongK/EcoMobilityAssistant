{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "Enabled": true
    }
  },
  "McpSettings": {
    "SseUrl": "", // sse url, the container will listen to this url for sse messages, and forward them to the client
    "TransportType": "sse", // or stdio for local IPC testing
    "MaxChatMemoryItems": 10, // memory chat length
    "LocalModelName": "ollama3", // if there is a local model, use it, otherwise use cloud model
    "CloudModelName": "gpt-4o-mini", // if there is no local model, use this cloud model
    "ServerPath": "../McpServer/src/EcoMob.McpServer.Entry/bin/Release/net8.0/win-x64/publish/EcoMob.McpServer.Entry.exe", // mcp server path for local testing
    "OpenAIKey": ""
  }
}
