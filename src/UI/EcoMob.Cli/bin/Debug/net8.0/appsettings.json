{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "Enabled": true
    }
  },
  "McpSettings": {
    "SseUrl": "http://localhost:5134/sse", // sse url, the container will listen to this url for sse messages, and forward them to the client
    "TransportType": "stdio", // or stdio for local IPC testing
    "MaxChatMemoryItems": 10, // memory chat length
    "LocalModelName": "ollama3", // if there is a local model, use it, otherwise use cloud model
    "CloudModelName": "gpt-4o-mini", // if there is no local model, use this cloud model
    "ServerPath": "",
    "OpenAIKey": ""
  }
}
